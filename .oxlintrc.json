{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "env": {
    "builtin": true,
    "node": true,
    "browser": true
  },
  "ignorePatterns": ["dist/**", "node_modules/**", "types/cdp.ts", "types/zod.ts"],
  "rules": {
    "no-console": "off",
    "no-empty": "off",
    "typescript/no-explicit-any": "off"
  }
}
