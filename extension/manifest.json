{
  "manifest_version": 3,
  "name": "MagicCDP Bridge",
  "version": "0.1.0",
  "description": "Extension service worker bridge for MagicCDP custom commands and events.",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "ws://localhost/*",
    "ws://127.0.0.1/*"
  ]
}
