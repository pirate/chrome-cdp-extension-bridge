{
  "manifest_version": 3,
  "name": "MagicCDP",
  "version": "0.1.0",
  "description": "MagicCDP server bridge. Custom CDP commands + events are bootstrapped into this service worker by the client at connect() time.",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "permissions": [
    "debugger",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "ws://localhost/*",
    "ws://127.0.0.1/*"
  ]
}
